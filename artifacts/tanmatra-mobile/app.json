{
  "expo": {
    "name": "Tanmatra Mobile",
    "slug": "tanmatra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tanmatra-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "backgroundColor": "#050505",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Tanmatra reads your daily steps and active calories from Apple Health to keep your wellness dashboard in sync.",
        "NSHealthUpdateUsageDescription": "Tanmatra does not write to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-health",
        {
          "healthSharePermission": "Tanmatra reads your daily steps and active calories from Apple Health to keep your wellness dashboard in sync.",
          "healthUpdatePermission": "Tanmatra does not write to Apple Health."
        }
      ],
      "react-native-health-connect"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
