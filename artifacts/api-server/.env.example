# ── Database ──────────────────────────────────────────────────────────────────
# Cloud SQL socket (production):
DATABASE_URL=postgresql://postgres:PASSWORD@/neondb?host=/cloudsql/PROJECT:REGION:INSTANCE
# Local dev via proxy (port 9470):
# DATABASE_URL=postgresql://postgres:PASSWORD@localhost:9470/neondb

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://tanmatra.food,https://www.tanmatra.food

# ── Admin auth ────────────────────────────────────────────────────────────────
# Generate with: POST /admin/_hash { "password": "yourpassword" } (provide
# x-admin-secret header = ADMIN_SESSION_SECRET).
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt$16384$8$1$SALT_HEX$HASH_HEX
# Must be ≥ 32 characters.
ADMIN_SESSION_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING

# ── Consumer auth ─────────────────────────────────────────────────────────────
# Cookie security — set to "1" only in local dev over HTTP.
INSECURE_DEV_COOKIE=0
SESSION_SAMESITE=lax

# ── Payments — Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
# From Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── SMS / OTP — MSG91 ─────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=TANMTR
MSG91_TEMPLATE_ID=

# ── AI — Google Gemini ────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...

# ── Cloud SQL ─────────────────────────────────────────────────────────────────
CLOUD_SQL_INSTANCE=project:region:instance

# ── RD admin token (legacy — prefer signed admin cookie) ──────────────────────
RD_ADMIN_TOKEN=

# ── Optional: ops override bulkhead DB (defaults to DATABASE_URL if unset) ───
# OVERRIDE_DATABASE_URL=
